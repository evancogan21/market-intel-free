# --- REQUIRED ---

# Free, instant signup. https://fredaccount.stlouisfed.org/apikey
FRED_API_KEY=

# Required by SEC EDGAR — they want a name + contact so they can throttle abusers.
SEC_USER_AGENT=Evan Cogan evancogan21@gmail.com


# --- AUTO-PROVIDED BY GITHUB ACTIONS ---
# (You don't set these — Actions sets them at runtime.)
# GITHUB_TOKEN
# GITHUB_REPOSITORY


# --- OPTIONAL: Telegram phone push ---
# Talk to @BotFather on Telegram, run /newbot, copy the token.
# Then message your new bot once and visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# to grab the chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# --- OPTIONAL: Fully-automated mode using Google Gemini free tier ---
# 1500 requests/day free, no credit card required.
# https://aistudio.google.com/apikey
# If set, the action runs the prompt through Gemini and posts the AI-generated
# briefing directly. If unset, you paste into Claude.ai instead.
GEMINI_API_KEY=
